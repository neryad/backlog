{
  "expo": {
    "name": "Playlogged",
    "slug": "playlogged",
    "scheme": "playlogged",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icons/splash-icon-dark.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/icons/splash-icon-dark.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f0f13"
    },
    "ios": {
      "supportsTablet": true,
      "icon": {
        "dark": "./assets/icons/ios-dark.jpg",
        "light": "./assets/icons/ios-light.jpg",
        "tinted": "./assets/icons/ios-tinted.jpg"
      },
      "bundleIdentifier": "com.neryad.playlogged",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0f0f13",
        "foregroundImage": "./assets/icons/adaptive-icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.neryad.playlogged"
    },
    "web": {
      "favicon": "./assets/icons/adaptive-icon.png"
    },
    "plugins": [
      "expo-sqlite",
      "expo-router",
      "expo-image",
      "expo-secure-store",
      "expo-font"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ae1de6c4-5881-4e0f-a6dc-74412572bc7e"
      }
    }
  }
}
