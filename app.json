{
  "expo": {
    "name": "Playlogged",
    "slug": "playlogged",
    "scheme": "playlogged",
    "main": "expo-router/entry",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/icons/splash-icon-dark.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f0f13"
    },
    "ios": {
      "supportsTablet": true,
      "icon": {
        "dark": "./assets/icons/ios-dark.jpg",
        "light": "./assets/icons/ios-light.jpg",
        "tinted": "./assets/icons/ios-tinted.jpg"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0f0f13",
        "foregroundImage": "./assets/icons/adaptive-icon.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/icons/adaptive-icon.png"
    },
    "plugins": ["expo-sqlite", "expo-router", "expo-image"]
  }
}
